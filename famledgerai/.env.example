# Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to Git!

# ===== Financial APIs =====

# Alpha Vantage (Stock Prices)
# Free tier: 5 API calls/minute, 500/day
# Get your key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Metals-API (Gold Prices)
# Free tier: 50 requests/month
# Get your key: https://metals-api.com/
METALS_API_KEY=your_metals_api_key_here

# Finnhub (Financial News)
# Free tier: 60 calls/minute
# Get your key: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_key_here

# ===== Supabase (Database) =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ===== Twilio (WhatsApp) =====
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ===== Optional: Broker APIs (Premium Features) =====
# Zerodha Kite Connect
# KITE_API_KEY=your_kite_api_key
# KITE_API_SECRET=your_kite_api_secret

# Upstox API
# UPSTOX_API_KEY=your_upstox_api_key
# UPSTOX_API_SECRET=your_upstox_api_secret

# ===== Optional: Redis/Caching =====
# For production, use Redis or Vercel KV
# REDIS_URL=redis://localhost:6379
# UPSTASH_REDIS_REST_URL=your_upstash_url
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ===== Optional: Monitoring =====
# SENTRY_DSN=your_sentry_dsn
# LOGTAIL_TOKEN=your_logtail_token
