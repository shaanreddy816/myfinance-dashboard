{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...catchall].js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "crons": [
    {
      "path": "/api/aa/refresh",
      "schedule": "30 0 * * *"
    }
  ]
}